generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Renamedcase {
  id             String           @id
  type           String
  description    String?
  lat            Float?
  lng            Float?
  status         String           @default("OPEN")
  createdAt      DateTime         @default(now())
  title          String?          @default("حالة غير معنونة")
  city           String?          @default("طرابلس")
  campaignId     String?
  campaign       campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  caseassignment caseassignment[]
  visit          visit[]

  @@index([campaignId])
  @@map("case")
}

model caseassignment {
  id          String      @id
  caseId      String
  userId      String
  createdAt   DateTime    @default(now())
  Renamedcase Renamedcase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user        user        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([caseId, userId])
}

model city {
  id        String   @id
  name      String   @unique
  createdAt DateTime @default(now())
}

model committee {
  id        String   @id
  name      String   @unique
  createdAt DateTime @default(now())
}

model campaign {
  id          String           @id
  name        String
  city        String
  status      String           @default("ACTIVE")
  visibility  String           @default("PRIVATE")
  description String?
  isDefault   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  members     campaignmember[]
  cemeteries  cemetery[]
  cases       Renamedcase[]

  @@map("campaign")
}

model campaignmember {
  id         String   @id
  campaignId String
  userId     String
  createdAt  DateTime @default(now())
  campaign   campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@map("campaignmember")
}

model cemetery {
  id         String   @id
  name       String
  campaignId String
  lat        Float?
  lng        Float?
  notes      String?
  images     String?
  voiceData  String?
  status     String   @default("PENDING")
  addedBy    String
  createdAt  DateTime @default(now())
  campaign   campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       user     @relation(fields: [addedBy], references: [id])
  visits     visit[]

  @@index([campaignId])
  @@index([addedBy])
  @@map("cemetery")
}

model user {
  id             String           @id
  role           String           @default("SPECIALIST")
  name           String?
  createdAt      DateTime         @default(now())
  committee      String?
  phone          String?
  photo          String?
  status         String           @default("ACTIVE")
  whatsapp       String?
  password       String?
  caseassignment caseassignment[]
  visit          visit[]
  campaignmember campaignmember[]
  cemetery       cemetery[]
}

model visit {
  id          String       @id
  userId      String
  caseId      String?
  lat         Float
  lng         Float
  notes       String?
  timestamp   DateTime     @default(now())
  images      String?
  videos      String?
  voiceData   String?
  Renamedcase Renamedcase? @relation(fields: [caseId], references: [id], onDelete: Cascade)
  cemetery    cemetery?    @relation(fields: [cemeteryId], references: [id], onDelete: Cascade)
  cemeteryId  String?
  user        user         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([cemeteryId])
  @@index([userId])
}
